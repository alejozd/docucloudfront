```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.class
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build directories
dist/
build/
target/
*.jar
*.war
*.zip
*.tar.gz

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo
*.bak
*.~
*~

# OS generated files
.DS_Store
Thumbs.db
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Icon?
Network Trash Folder
Temporary Items
.apdisk

# IDE specific
.vscode/
.idea/
*.iml
*.ipr
*.iws
.settings/
nbproject/
nbbuild/
nbdist/
.npebuild/
build/
dist/
target/
*.tmproj
*.sublime-project
*.sublime-workspace
**/logs/

# Python specific
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Node.js specific
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/node_modules
/.pnp
.pnp.js

# Coverage reports
coverage/
*.coverage
.htmlcov/

# Testing
.ruby-version
.bundle
.plt
.pytest_cache/
.mypy_cache/

# Environment variable files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Local configuration files
config.local.json
*.local
```