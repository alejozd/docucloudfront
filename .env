# Variables de entorno para el módulo de descarga de audios desde YouTube

# URL del backend API
REACT_APP_API_URL=http://localhost:3100

# API Key para autenticación con el backend (ZAM_API_KEY)
# DEBE SER LA MISMA QUE LA CONFIGURADA EN EL BACKEND
REACT_APP_API_KEY=tu-zam-api-key-aqui-misma-que-el-backend
