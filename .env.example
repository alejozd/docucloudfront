# Variables de entorno para el módulo de descarga de audios desde YouTube

# URL del backend API
REACT_APP_API_URL=http://localhost:3100

# API Key para autenticación con el backend (ZAM_API_KEY)
REACT_APP_ZAM_API_KEY=tu-zam-api-key-aqui

# API Key específica para el módulo de audio (opcional, usa ZAM_API_KEY si no se define)
REACT_APP_AUDIO_API_KEY=tu-zam-api-key-aqui

# Password para acceder al módulo de audios YouTube
REACT_APP_AUDIO_PASSWORD=admin123
